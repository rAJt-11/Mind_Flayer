# ─── Mind Flayer - Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in your values

# ─── MSSQL Database ─────────────────────────────────────────────────────────
MSSQL_SERVER=10.40.2.120
MSSQL_DATABASE=SCM_DEV
MSSQL_USERNAME=sa
MSSQL_PASSWORD=Haier@2025
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

DATABASE_URL=sqlite+aiosqlite:///./mind_flayer.db
SYNC_DATABASE_URL=sqlite:///./mind_flayer.db

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=True
APP_NAME=Mind Flayer

# ─── Auth / Security ─────────────────────────────────────────────────────────
SECRET_KEY=mind-flayer-super-secret-key-change-in-production-32chars!!
SESSION_SECRET_KEY=session-secret-key-change-in-production-must-be-long!!
JWT_SECRET_KEY=jwt-secret-key-change-in-production-very-long-secret-key!!
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
